---
// TemplatesPreview.astro — Dark band section for templates
---

<section id="templates" class="py-24 bg-ink text-canvas overflow-hidden">
  <div class="page-container-wide relative z-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
      <div class="max-w-2xl">
        <h2 class="text-caption-mono text-cyan mb-2">Templates</h2>
        <h3 class="text-display-lg text-canvas">ATS-friendly templates.<br />Zero formatting required.</h3>
        <p class="text-body-lg text-mute mt-4">
          Choose from 8 professionally designed, ATS-tested templates. See your actual resume data in each template before you download.
        </p>
      </div>
      <a href="/scan" class="btn-primary bg-canvas text-ink hover:bg-canvas-soft border border-transparent self-start md:self-end shrink-0">
        Browse All Templates
      </a>
    </div>

    <!-- Template Carousel (CSS Scroll Snap) -->
    <div class="flex gap-6 overflow-x-auto pb-8 snap-x snap-mandatory hide-scrollbar">
      <!-- Template 1 -->
      <div class="snap-start shrink-0 w-[300px] flex flex-col gap-4 group cursor-pointer">
        <div class="aspect-[1/1.4] bg-canvas rounded-lg p-2 shadow-level-3 overflow-hidden border border-mute/20 group-hover:border-cyan/50 transition-colors relative">
          <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 flex items-end p-4">
             <span class="text-canvas text-body-sm-strong">Preview</span>
          </div>
          <!-- Abstract representation of Professional template -->
          <div class="w-full h-full border border-hairline bg-canvas-soft/50 p-4 flex flex-col gap-2">
            <div class="h-6 w-3/4 bg-ink/10 rounded mx-auto mb-2"></div>
            <div class="h-2 w-1/2 bg-ink/5 rounded mx-auto mb-4"></div>
            <div class="h-4 w-1/3 bg-ink/10 rounded mb-1"></div>
            <div class="h-1 w-full bg-ink/20 mb-2"></div>
            <div class="h-2 w-full bg-ink/5 rounded mb-1"></div>
            <div class="h-2 w-full bg-ink/5 rounded mb-1"></div>
            <div class="h-2 w-5/6 bg-ink/5 rounded mb-4"></div>
          </div>
        </div>
        <div>
          <h4 class="text-body-md-strong text-canvas">Professional</h4>
          <p class="text-body-sm text-mute">Classic single-column layout.</p>
        </div>
      </div>

      <!-- Template 2 -->
      <div class="snap-start shrink-0 w-[300px] flex flex-col gap-4 group cursor-pointer">
        <div class="aspect-[1/1.4] bg-canvas rounded-lg p-2 shadow-level-3 overflow-hidden border border-mute/20 group-hover:border-cyan/50 transition-colors relative">
           <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 flex items-end p-4">
             <span class="text-canvas text-body-sm-strong">Preview</span>
          </div>
          <!-- Abstract representation of Modern template -->
          <div class="w-full h-full border border-hairline bg-canvas-soft/50 flex">
             <div class="w-1/3 h-full bg-ink/5 p-2 flex flex-col gap-2 border-r border-hairline">
                <div class="h-4 w-full bg-ink/10 rounded mb-2"></div>
                <div class="h-2 w-full bg-ink/5 rounded mb-1"></div>
                <div class="h-2 w-3/4 bg-ink/5 rounded mb-4"></div>
             </div>
             <div class="w-2/3 p-3 flex flex-col gap-2">
                <div class="h-5 w-3/4 bg-ink/10 rounded mb-1"></div>
                <div class="h-2 w-1/2 bg-ink/5 rounded mb-4"></div>
                <div class="h-3 w-1/3 bg-ink/10 rounded mb-1"></div>
                <div class="h-2 w-full bg-ink/5 rounded mb-1"></div>
                <div class="h-2 w-full bg-ink/5 rounded mb-1"></div>
             </div>
          </div>
        </div>
        <div>
          <h4 class="text-body-md-strong text-canvas">Modern</h4>
          <p class="text-body-sm text-mute">Two-column with sidebar.</p>
        </div>
      </div>

       <!-- Template 3 -->
      <div class="snap-start shrink-0 w-[300px] flex flex-col gap-4 group cursor-pointer">
        <div class="aspect-[1/1.4] bg-canvas rounded-lg p-2 shadow-level-3 overflow-hidden border border-mute/20 group-hover:border-cyan/50 transition-colors relative">
           <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 flex items-end p-4">
             <span class="text-canvas text-body-sm-strong">Preview</span>
          </div>
          <div class="w-full h-full border border-hairline bg-canvas-soft/50 p-4 flex flex-col gap-3">
             <div class="flex items-center gap-3 mb-4">
                 <div class="w-8 h-8 rounded-full bg-ink/10"></div>
                 <div>
                    <div class="h-4 w-24 bg-ink/10 rounded mb-1"></div>
                    <div class="h-2 w-16 bg-ink/5 rounded"></div>
                 </div>
             </div>
             <div class="h-3 w-1/3 bg-ink/10 rounded mb-1"></div>
             <div class="h-2 w-full bg-ink/5 rounded mb-1"></div>
             <div class="h-2 w-full bg-ink/5 rounded mb-1"></div>
          </div>
        </div>
        <div>
          <h4 class="text-body-md-strong text-canvas">Creative</h4>
          <p class="text-body-sm text-mute">Subtle accents & typography.</p>
        </div>
      </div>
      
       <!-- Template 4 -->
      <div class="snap-start shrink-0 w-[300px] flex flex-col gap-4 group cursor-pointer opacity-50">
        <div class="aspect-[1/1.4] bg-canvas rounded-lg p-2 shadow-level-3 overflow-hidden border border-mute/20 flex items-center justify-center">
            <span class="text-body-sm text-mute">+ 5 more templates</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
