---
// HeroSection.astro — Hero with mesh gradient and primary CTAs
---

<section
  class="relative min-h-[100svh] flex flex-col justify-center py-20 md:py-32 overflow-hidden bg-canvas"
>
  <!-- Mesh Gradient Background -->
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden flex justify-center opacity-70"
  >
    <div
      class="mesh-gradient absolute w-[150%] h-[150%] -top-[50%] blur-3xl opacity-30 transform-gpu animate-pulse"
      style="animation-duration: 8s;"
    >
    </div>
  </div>

  <div
    class="page-container relative z-10 flex flex-col items-center text-center"
  >
    <!-- Announcement Banner -->

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold max-w-5xl mb-6 text-ink tracking-tight text-center leading-tight whitespace-nowrap">
      Don't <span
        style="text-decoration: line-through; text-decoration-color: #ef4444; text-decoration-thickness: 0.1em;"
        >beat the ATS</span
      >
    </h1>
    
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold max-w-3xl mb-4 text-ink/90 tracking-tight text-center text-balance leading-snug">
      Instead show clarity, impact, outcome and make it align with JD.
    </h2>

    <p class="text-xl sm:text-2xl italic text-ink/70 max-w-2xl mb-10 text-center font-medium">
      Things Recruiter actually care.
    </p>

    <!-- Subheadline -->
    <p class="text-body-lg text-body max-w-2xl mb-10 text-balance text-center">
      Upload your resume and job description. Get an instant recruiter
      evaluation — skill gap analysis, readability score, impact assessment, and
      shortlist probability.
    </p>

    <!-- CTA Cluster -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
      <a href="/scan" class="btn-primary w-full sm:w-auto shadow-level-2">
        Get Recruiter Feedback
      </a>
      <a
        href="#how-it-works"
        class="btn-secondary w-full sm:w-auto bg-canvas/50 backdrop-blur-sm"
      >
        See How It Works
      </a>
    </div>
  </div>
</section>
