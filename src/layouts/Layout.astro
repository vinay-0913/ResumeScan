---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Resumescan — See Your Resume Through a Recruiter\'s Eyes',
  description = 'Upload your resume and job description. Get an instant recruiter evaluation — skill gap analysis, readability score, impact assessment, and shortlist probability — completely free.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://resumescan.com" />
    <meta property="og:site_name" content="Resumescan" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href="https://resumescan.com" />

    <!-- Fonts: Inter via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Resumescan",
      "url": "https://resumescan.com",
      "description": "AI-powered resume evaluation tool that analyzes your resume the way a real recruiter would — providing skill gap analysis, readability assessment, impact evaluation, shortlist probability, and actionable improvement suggestions.",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Career Development Tool",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free AI recruiter evaluation"
      }
    })} />
  </head>
  <body class="min-h-screen bg-canvas-soft text-ink antialiased">
    <slot />
  </body>
</html>
