---
// Footer.astro — 4-column footer
---

<footer class="bg-canvas border-t border-hairline py-16">
  <div class="page-container-wide grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">
    <!-- Brand Column -->
    <div class="flex flex-col gap-4">
      <a href="/" class="flex items-center gap-2 text-ink no-underline group">
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none" class="transition-transform duration-200 group-hover:scale-105">
          <rect width="32" height="32" rx="8" fill="#171717"/>
          <path d="M8 10h16M8 16h12M8 22h8" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="24" cy="22" r="4" fill="#007cf0" stroke="#171717" stroke-width="1"/>
          <path d="M22.5 22l1 1 2-2" stroke="#fff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="text-body-sm-strong text-ink">Resumescan</span>
      </a>
      <p class="text-body-sm text-body max-w-[250px]">
        The free, AI-powered resume evaluation tool that helps you see your resume through a recruiter's eyes and land more interviews.
      </p>
    </div>

    <!-- Product Column -->
    <div class="flex flex-col gap-4">
      <h3 class="text-caption-mono text-ink">Product</h3>
      <a href="/scan" class="text-body-sm text-body hover:text-link transition-colors">Recruiter Evaluation</a>
      <a href="#features" class="text-body-sm text-body hover:text-link transition-colors">Resume Improvements</a>
      <a href="#features" class="text-body-sm text-body hover:text-link transition-colors">Skill Gap Analysis</a>
      <span class="text-body-sm text-mute cursor-not-allowed">Cover Letter Generator <span class="badge ml-1 bg-canvas-soft-2">Soon</span></span>
    </div>

    <!-- Resources Column -->
    <div class="flex flex-col gap-4">
      <h3 class="text-caption-mono text-ink">Resources</h3>
      <a href="#how-it-works" class="text-body-sm text-body hover:text-link transition-colors">How it Works</a>
      <a href="#faq" class="text-body-sm text-body hover:text-link transition-colors">FAQ</a>
      <a href="#" class="text-body-sm text-body hover:text-link transition-colors">Resume Examples</a>
      <a href="#" class="text-body-sm text-body hover:text-link transition-colors">Career Advice</a>
    </div>

    <!-- Legal Column -->
    <div class="flex flex-col gap-4">
      <h3 class="text-caption-mono text-ink">Company</h3>
      <a href="#" class="text-body-sm text-body hover:text-link transition-colors">About Us</a>
      <a href="#" class="text-body-sm text-body hover:text-link transition-colors">Contact</a>
      <a href="#" class="text-body-sm text-body hover:text-link transition-colors">Privacy Policy</a>
      <a href="#" class="text-body-sm text-body hover:text-link transition-colors">Terms of Service</a>
    </div>
  </div>

  <div class="page-container-wide mt-16 pt-8 border-t border-hairline flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-caption text-mute">
      © {new Date().getFullYear()} Resumescan. All rights reserved.
    </p>
    
    <!-- Social Links -->
    <div class="flex items-center gap-4">
      <a href="#" class="text-mute hover:text-ink transition-colors" aria-label="Twitter">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="#" class="text-mute hover:text-ink transition-colors" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
      </a>
    </div>
  </div>
</footer>
