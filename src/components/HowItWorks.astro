---
// HowItWorks.astro — 3-step flow on canvas-soft
---

<section id="how-it-works" class="py-24 bg-canvas-soft border-y border-hairline">
  <div class="page-container">
    <div class="text-center mb-16">
      <h2 class="text-caption-mono text-link mb-2">How It Works</h2>
      <h3 class="text-display-lg text-ink">Three steps to your next interview.</h3>
      <p class="text-body-lg text-body mt-4 max-w-2xl mx-auto">
        Stop guessing what recruiters want. Get an AI-powered evaluation that tells you exactly how a hiring manager would assess your resume.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Step 1 -->
      <div class="card-marketing shadow-level-2 border border-hairline relative overflow-hidden group hover:shadow-level-3 transition-shadow">
        <div class="absolute -top-4 -right-4 text-9xl font-black text-canvas-soft-2 opacity-50 select-none z-0">1</div>
        <div class="relative z-10 flex flex-col gap-4">
          <div class="w-12 h-12 rounded-full bg-canvas-soft border border-hairline flex items-center justify-center text-ink mb-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h4 class="text-display-sm text-ink">Upload your files</h4>
          <p class="text-body-md text-body">
            Upload your current resume (PDF) and paste the job description you're targeting. No account required.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="card-marketing shadow-level-2 border border-hairline relative overflow-hidden group hover:shadow-level-3 transition-shadow">
        <div class="absolute -top-4 -right-4 text-9xl font-black text-canvas-soft-2 opacity-50 select-none z-0">2</div>
        <div class="relative z-10 flex flex-col gap-4">
          <div class="w-12 h-12 rounded-full bg-canvas-soft border border-hairline flex items-center justify-center text-ink mb-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h4 class="text-display-sm text-ink">Review your recruiter evaluation</h4>
          <p class="text-body-md text-body">
            Get a comprehensive analysis — match score, shortlist probability, skill gaps, readability grade, and impact assessment.
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="card-marketing shadow-level-2 border border-hairline relative overflow-hidden group hover:shadow-level-3 transition-shadow">
        <div class="absolute -top-4 -right-4 text-9xl font-black text-canvas-soft-2 opacity-50 select-none z-0">3</div>
        <div class="relative z-10 flex flex-col gap-4">
          <div class="w-12 h-12 rounded-full bg-canvas-soft border border-hairline flex items-center justify-center text-ink mb-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h4 class="text-display-sm text-ink">Get actionable improvements</h4>
          <p class="text-body-md text-body">
            Receive specific, evidence-based rewrite suggestions with before/after comparisons and reasoning — ready to apply.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
